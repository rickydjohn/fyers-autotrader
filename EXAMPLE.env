# Fyers credentials
FYERS_CLIENT_ID=your_client_id
FYERS_SECRET_KEY=your_secret_key
FYERS_REDIRECT_URI=http://localhost:8001/fyers/callback

# Fyers TOTP automated login (optional but recommended)
# Without these, you must visit /fyers/auth manually each morning.
# FYERS_USER_ID: your Fyers account ID (e.g. XY12345)
# FYERS_PIN: your 4-digit Fyers trading PIN
# FYERS_TOTP_KEY: base32 TOTP secret from Fyers account → My Account → Security → TOTP
FYERS_USER_ID=your_fyers_account_id
FYERS_PIN=your_4digit_pin
FYERS_TOTP_KEY=your_totp_secret_key

# Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=your_model_name
OLLAMA_TIMEOUT=120

# Redis
REDIS_URL=redis://redis:6379

# Simulation
INITIAL_BUDGET=100000
MAX_POSITION_SIZE_PCT=10
SLIPPAGE_PCT=0.05
COMMISSION_FLAT=20

# Database (TimescaleDB)
DATABASE_URL=postgresql+asyncpg://trading:trading@timescaledb:5432/trading
POSTGRES_DB=trading
POSTGRES_USER=trading
POSTGRES_PASSWORD=your_db_password

# Data Service
DATA_SERVICE_URL=http://data-service:8003
CONTEXT_LOOKBACK_DAYS=5

# App
LOG_LEVEL=INFO
ENVIRONMENT=simulation
MARKET_OPEN=09:15
MARKET_CLOSE=15:30
SCAN_INTERVAL_SECONDS=60
POSITION_WATCHER_INTERVAL_SECONDS=5

# Proxy (optional — all four must be set to activate; only fyers.in traffic is affected)
PROXY_IP=your_proxy_ip
PROXY_PORT=3128
PROXY_USER=your_proxy_user
PROXY_PASSWORD=your_proxy_password
