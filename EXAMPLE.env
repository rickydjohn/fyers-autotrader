# ─── Fyers API ────────────────────────────────────────────────────────────────
FYERS_CLIENT_ID=your_client_id
FYERS_SECRET_KEY=your_secret_key
FYERS_REDIRECT_URI=http://localhost:8001/fyers/callback

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# "ollama" (local, no API cost) or "claude" (cloud, recommended for quality)
LLM_PROVIDER=ollama

# Ollama — used when LLM_PROVIDER=ollama
OLLAMA_ENDPOINT=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:latest
OLLAMA_TIMEOUT=120

# Claude (Anthropic) — used when LLM_PROVIDER=claude
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_ENDPOINT=https://api.anthropic.com
CLAUDE_TIMEOUT=30

# ─── Market / Candle Settings ─────────────────────────────────────────────────
# Candle resolution fetched from Fyers.
# "1m" = fetch 1m bars, aggregate to 5m in-process (default, best for forming-bar signal).
# "5m" = fetch 5m bars directly (forming-bar signal becomes silent).
# To replicate pre-1m behaviour fully: CANDLE_INTERVAL=5m + MIN_BAR_POSITION=4
CANDLE_INTERVAL=1m

# How many minutes into the current 5m bar before the LLM is allowed to run.
# 0 = first minute (very noisy), 2 = third minute (default), 4 = last minute (conservative).
MIN_BAR_POSITION=2

# How often (seconds) to run the full LLM decision cycle per symbol.
# Each cycle = fetch candles + compute indicators + build prompt + LLM call
# (~29s on Ollama 120b) + persist. Setting <60s queues scans behind the LLM
# call; 60s is the natural minimum.
LLM_DECISION_INTERVAL_SECONDS=60

# No new positions opened at or after this time (IST).
SESSION_CLOSE_HOUR=15
SESSION_CLOSE_MINUTE=15

# ─── Simulation / Risk ────────────────────────────────────────────────────────
INITIAL_BUDGET=100000
MAX_POSITION_SIZE_PCT=10
SLIPPAGE_PCT=0.05
COMMISSION_FLAT=20

# Minimum option premium (₹) — below this, a 10% stop-loss sits inside the spread.
MIN_OPTION_PREMIUM=30

# Minutes to block re-entry on an underlying after a stop-loss or trail-stop.
SL_COOLDOWN_MINUTES=15

# ─── Database (TimescaleDB) ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://trading:trading@timescaledb:5432/trading
POSTGRES_DB=trading
POSTGRES_USER=trading
POSTGRES_PASSWORD=your_db_password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Service URLs (internal Docker network) ───────────────────────────────────
DATA_SERVICE_URL=http://data-service:8003
CORE_ENGINE_URL=http://core-engine:8001
SIM_ENGINE_URL=http://simulation-engine:8002

# ─── Data Service ─────────────────────────────────────────────────────────────
# How many days of candle history to include in each LLM context snapshot.
CONTEXT_LOOKBACK_DAYS=5

# ─── Notifications ────────────────────────────────────────────────────────────
# Optional — leave blank to disable Slack alerts.
SLACK_WEBHOOK_URL=

# ─── App ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# "simulation" = paper trading (default). "live" = real orders via Fyers broker.
ENVIRONMENT=simulation
# How often (seconds) to poll Greeks (delta, gamma, theta, vega, IV) for
# any open option positions. Greeks are NOT pushed over the Fyers WebSocket
# — only available via a REST endpoint — so this is the one polling cadence
# that the WS migration didn't eliminate. Underlying + option *prices* are
# now WS-fed (~200ms cadence) and don't depend on this interval.
GREEKS_POLL_INTERVAL_SECONDS=5

# ─── Proxy (optional) ─────────────────────────────────────────────────────────
# All four must be set to activate. Routes all fyers.in traffic through the
# proxy with IPv4 forced (disables IPv6). Leave blank if no proxy needed.
PROXY_IP=
PROXY_PORT=3128
PROXY_USER=
PROXY_PASSWORD=
